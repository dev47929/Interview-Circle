
# =========================
# Root .gitignore
# Project Structure:
# backend/  -> Python (FastAPI / Django / Flask etc.)
# frontend/ -> React / Vite / Next etc.
# Handles multiple nested subfolders too
# =========================


# =========================================================
# GENERAL
# =========================================================

.DS_Store
Thumbs.db
*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*.pid


# =========================================================
# ENV FILES
# =========================================================

.env
.env.*
!.env.example
*.env


# =========================================================
# PYTHON (backend/)
# =========================================================

# Byte-compiled / optimized / DLL files
backend/**/__pycache__/
backend/**/*.py[cod]
backend/**/*$py.class

# Virtual environments
backend/**/venv/
backend/**/.venv/
backend/**/env/
backend/**/.env/

# Python distribution / packaging
backend/**/build/
backend/**/dist/
backend/**/*.egg-info/
backend/**/*.egg
backend/**/.eggs/

# Testing
backend/**/.pytest_cache/
backend/**/.coverage
backend/**/htmlcov/
backend/**/.tox/
backend/**/.nox/

# Type checking / linting
backend/**/.mypy_cache/
backend/**/.ruff_cache/
backend/**/.pyre/
backend/**/.pytype/

# Jupyter
backend/**/*.ipynb_checkpoints

# SQLite
backend/**/*.sqlite3
backend/**/*.db

# IDE
backend/**/.idea/
backend/**/.vscode/


# =========================================================
# REACT / NODE (frontend/)
# =========================================================

# Node modules
frontend/**/node_modules/

# Build outputs
frontend/**/build/
frontend/**/.next/
frontend/**/out/
frontend/**/.turbo/

# Cache
frontend/**/.cache/
frontend/**/.parcel-cache/
frontend/**/.vite/
frontend/**/.eslintcache

# Logs
frontend/**/npm-debug.log*
frontend/**/yarn-debug.log*
frontend/**/yarn-error.log*
frontend/**/pnpm-debug.log*

# Coverage
frontend/**/coverage/

# IDE
frontend/**/.idea/
frontend/**/.vscode/


# =========================================================
# DATABASE / MIGRATIONS (optional)
# =========================================================

*.sql
*.dump
*.backup


# =========================================================
# OS / Editor
# =========================================================

.vscode/
.idea/
*.sublime-workspace
*.sublime-project